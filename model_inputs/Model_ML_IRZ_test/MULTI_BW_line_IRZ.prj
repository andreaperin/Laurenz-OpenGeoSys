    <time_loop>
        <processes>
            <process ref="thermohydraulic">
                <nonlinear_solver>basic_picard</nonlinear_solver>
                <convergence_criterion>
                    <type>PerComponentDeltaX</type>
                    <norm_type>NORM2</norm_type>
					<reltols>1e-5 1e-5</reltols>
					<abstols>1e-8 1e-8</abstols>
                </convergence_criterion>
                <time_discretization>
                    <type>BackwardEuler</type>
                </time_discretization>
				<time_stepping>
					<type>IterationNumberBasedTimeStepping</type>
					<t_initial>0.0</t_initial>
					<t_end>2365200000</t_end>
					<initial_dt>0.1</initial_dt>
					<minimum_dt>0.01</minimum_dt>
					<maximum_dt>15768000</maximum_dt>
					<number_iterations>2 6 8 9</number_iterations>
					<multiplier>1.6 1.0 0.5 0.25</multiplier>
				</time_stepping>

			</process>
		</processes>
		<output>
			<type>VTK</type>
			<prefix>Multi_BW_line_IRZ</prefix>

			<fixed_output_times>
