    <parameters>

		<parameter>
			<name>T0</name>
			<type>MeshNode</type>			
			<field_name>T_ini</field_name>
		</parameter>
		<parameter>
			<name>T_boundary</name>
			<type>MeshNode</type>
			<mesh>Multi_BW_line_IRZ_physical_group_boundary_ini</mesh>
			<field_name>T_ini</field_name>
		</parameter>
        <parameter>
            <name>T_inj</name>
            <type>Constant</type>
            <value>30</value>
        </parameter>
        <parameter>
            <name>p_ini</name>  
		<!--	<type>Constant</type>
			<value>140e5</value>-->
           	<type>MeshNode</type>
			<field_name>pressure_ini</field_name>
        </parameter>
		<parameter>
			<name>p_boundary</name>
			<type>MeshNode</type>
			<mesh>Multi_BW_line_IRZ_physical_group_boundary_ini</mesh>
			<field_name>pressure_ini</field_name>
		</parameter>       
        <parameter>
            <name>clay_1_porosity_parameter</name>
            <type>Constant</type>
            <value>0.05</value>
        </parameter>
		<parameter>
			<name>clay_2_porosity_parameter</name>
			<type>Constant</type>
			<value>0.036</value>
		</parameter>
		<parameter>
			<name>sandstone_porosity_parameter_1</name>
			<type>Constant</type>
			<value>0.23</value>
		</parameter>
		<parameter>
			<name>sandstone_porosity_parameter_2</name>
			<type>Constant</type>
			<value>0.19</value>
		</parameter>
		<parameter>
			<name>sandstone_porosity_parameter_3</name>
			<type>Constant</type>
			<value>0.2</value>
		</parameter>
		<parameter>
			<name>sandstone_porosity_parameter_4</name>
			<type>Constant</type>
			<value>0.22</value>
		</parameter>		
		<parameter>
			<name>kappa_clay_1</name>
			<type>Constant</type>
			<values>9.87e-18</values>
		</parameter>
		<parameter>
			<name>kappa_clay_2</name>
			<type>Constant</type>
			<values>9.72e-16</values>
		</parameter>
		<parameter>
			<name>kappa_Sandstone_1</name>
			<type>Constant</type>
			<values>5.62e-13</values>			<!--Permeabilität von Sandstein 1-->
		</parameter>
		<parameter>
			<name>kappa_Sandstone_2</name>
			<type>Constant</type>
			<values>1.56e-13</values>			<!--Permeabilität von Sandstein 2-->
		</parameter>
		<parameter>
			<name>kappa_Sandstone_3</name>
			<type>Constant</type>
			<values>2.39e-13</values>			<!--Permeabilität von Sandstein 3-->
		</parameter>
		<parameter>
			<name>kappa_Sandstone_4</name>
			<type>Constant</type>
			<values>4.97e-13</values>			<!--Permeabilität von Sandstein 4-->
		</parameter>


		<parameter>
			<name>Inj_2</name>
			<type>Constant</type>
			<value>2.43e-4</value>		
		</parameter>
		<parameter>
			<name>Pump_2</name>
			<type>Constant</type>
			<value>-2.43e-4</value>			
		</parameter>
		<parameter>
			<name>Inj_3</name>
			<type>Constant</type>
			<value>3.72e-4</value>
		</parameter>
		<parameter>
			<name>Pump_3</name>
			<type>Constant</type>
			<value>-3.72e-4</value>
		</parameter>
		<parameter>
			<name>Inj_4</name>
			<type>Constant</type>
			<value>7.966e-4</value>
		</parameter>
		<parameter>
			<name>Pump_4</name>
			<type>Constant</type>
			<value>-7.966e-4</value>
		</parameter>
				
    </parameters>
    <process_variables>
        <process_variable>
            <name>T</name>
            <components>1</components>
            <order>1</order>
            <initial_condition>T0</initial_condition>

			<boundary_conditions>
		
				<boundary_condition>
					<mesh>Multi_BW_line_IRZ_physical_group_boundary_ini</mesh>
					<type>Dirichlet</type>
					<parameter>T_boundary</parameter>
				</boundary_condition>
				
				<boundary_condition>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_2</mesh>
					<type>Dirichlet</type>
					<parameter>T_inj</parameter>
				</boundary_condition>
				<boundary_condition>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_3</mesh>
					<type>Dirichlet</type>
					<parameter>T_inj</parameter>
				</boundary_condition>
				<boundary_condition>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_4</mesh>
					<type>Dirichlet</type>
					<parameter>T_inj</parameter>
				</boundary_condition>
            </boundary_conditions>
			
        </process_variable>
        <process_variable>
            <name>pressure</name>
            <components>1</components>
            <order>1</order>
            <initial_condition>p_ini</initial_condition>
			
          <boundary_conditions>

			  <boundary_condition>
				  <mesh>Multi_BW_line_IRZ_physical_group_boundary_ini</mesh>
				  <type>Dirichlet</type>
				  <parameter>p_boundary</parameter>
			  </boundary_condition>
			  
			</boundary_conditions>
			

			<source_terms>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_2</mesh>
					<type>Line</type>
					<parameter>Inj_2</parameter>
				</source_term>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Pump_line_2</mesh>
					<type>Line</type>
					<parameter>Pump_2</parameter>
				</source_term>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_3</mesh>
					<type>Line</type>
					<parameter>Inj_3</parameter>
				</source_term>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Pump_line_3</mesh>
					<type>Line</type>
					<parameter>Pump_3</parameter>
				</source_term>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Inj_line_4</mesh>
					<type>Line</type>
					<parameter>Inj_4</parameter>
				</source_term>
				<source_term>
					<mesh>Multi_BW_line_IRZ_physical_group_Pump_line_4</mesh>
					<type>Line</type>
					<parameter>Pump_4</parameter>
				</source_term>
			</source_terms> 
			
        </process_variable>
    </process_variables>
    <nonlinear_solvers>
        <nonlinear_solver>
            <name>basic_picard</name>		<!--auch bei Timeloop einfügen-->
            <type>Picard</type>
            <max_iter>300</max_iter>
            <linear_solver>general_linear_solver</linear_solver>
        </nonlinear_solver>
    </nonlinear_solvers>
    <linear_solvers>
        <linear_solver>
            <name>general_linear_solver</name>
         <!--   <lis>-i cg -p jacobi -tol 1e-8 -maxiter 5000</lis>-->		<!--integriert-->
            <eigen>
                <!-- <solver_type>PardisoLU</solver_type>
                <precon_type>NONE</precon_type> -->
                <!-- <solver_type>SparseLU</solver_type> -->
                <!-- <precon_type>DIAGONAL</precon_type> -->
                <precon_type>ILUT</precon_type>
                <solver_type>BiCGSTAB</solver_type>
                <max_iteration_step>5000</max_iteration_step>
                <error_tolerance>1e-12</error_tolerance>
            </eigen>
            <!--petsc>
                <prefix>gw</prefix>
                <parameters>-gw_ksp_type cg -gw_pc_type bjacobi -gw_ksp_rtol 1e-8 -gw_ksp_max_it 10000</parameters>
            </petsc-->
        </linear_solver>
    </linear_solvers>
